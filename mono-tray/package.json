{
  "name": "mono-tray",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run build -- --watch",
    "build": "bun run check && mkdir -p dist && bun build src/app.ts --outdir dist --minify && cp src/index.html src/style.css dist/",
    "check": "npx tsc --build --force",
    "fmt": "npx prettier --write 'src/**/*.ts'",
    "fmt:check": "npx prettier --check 'src/**/*.ts'",
    "tauri": "cargo tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "prettier": "^3.8.1",
    "serve": "^14.2.6",
    "typescript": "^5.9.3"
  }
}

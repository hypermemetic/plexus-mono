{
  "schema": "1.1",
  "language": "typescript",
  "backend": "music",
  "url": "ws://127.0.0.1:4448",
  "packageManager": "bun",
  "targets": {
    "client": {
      "generate": ["transport", "rpc", "plugins"],
      "transport": "browser",
      "outputDir": "generated"
    },
    "substrate-claudecode": {
      "backend": "substrate",
      "url": "ws://127.0.0.1:4444",
      "plugins": ["claudecode"],
      "generate": ["plugins"],
      "transport": "browser",
      "outputDir": "generated/substrate",
      "sharedTransport": "client"
    }
  }
}
